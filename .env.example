APP_ENV=dev

POSTGRES_DB=deshahed
POSTGRES_USER=deshahed
POSTGRES_PASSWORD=change-me

API_PORT=8000
WEB_PORT=3000

# Comma-separated CORS allow-list. In prod include the public frontend origin.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://xn----8sbkccc5iwa.online

# NEXT_PUBLIC_WS_URL is derived from window.location at runtime
# (see apps/web/src/lib/env.ts). Override only if the backend lives on a
# different host than the frontend in dev.
# NEXT_PUBLIC_WS_URL=

# Required to enable the alerts.in.ua poller (compose profile "with-poller"):
# ALERTS_API_TOKEN=

# Required to enable the Cloudflare Tunnel (compose profile "with-tunnel"):
# Get this from Cloudflare Zero Trust → Networks → Tunnels → <tunnel> → install
# command — the long string after `--token`. Ingress (Public Hostnames) is
# configured in the dashboard, not locally.
# TUNNEL_TOKEN=

# Sentry — leave empty to disable error reporting entirely.
# Backend project DSN:
# SENTRY_DSN=
# Frontend project DSN (browser + SSR). NEXT_PUBLIC_ → inlined into client bundle:
# NEXT_PUBLIC_SENTRY_DSN=

# Filled in later phases:
# TELEGRAM_API_ID=
# TELEGRAM_API_HASH=
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# SENTRY_DSN=
